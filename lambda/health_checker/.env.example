# Required — database (Aurora PostgreSQL)
POSTGRES_HOST=your-aurora-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ai_agent

# Required — Redis (ElastiCache)
REDIS_HOST=your-redis.xxxx.use1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_SSL=true

# Optional — AWS Bedrock
AWS_REGION=us-east-1

# Optional — Bedrock Knowledge Base
BEDROCK_KNOWLEDGE_BASE_ID=your-kb-id

# Optional — EFS
EFS_MOUNT_DIR=/mnt/efs

# Optional — main app health endpoint (internal ALB URL)
MAIN_APP_HEALTH_URL=http://internal-ai-agent-alb-xxxx.us-east-1.elb.amazonaws.com:8000/api/v1/health

# Optional — ECS cluster monitoring
ECS_CLUSTER_NAME=ai-agent-production-cluster
