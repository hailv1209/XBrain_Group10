# Backend API URL (for direct links like docs page)
# In production, this is the CloudFront domain (same origin)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (same origin in production via CloudFront /ws/* routing)
# Only set for local development pointing to backend directly
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Authentication (set to true when JWT or OAuth is enabled)
NEXT_PUBLIC_AUTH_ENABLED=true

# RAG (Retrieval Augmented Generation)
NEXT_PUBLIC_RAG_ENABLED=true
